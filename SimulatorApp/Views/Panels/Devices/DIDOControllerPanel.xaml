<UserControl x:Class="SimulatorApp.Views.Panels.Devices.DIDOControllerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="110"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FC" TargetType="ComboBox">
            <Setter Property="Width"      Value="120"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Background" Value="#242840"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3352"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="4,0,12,0"/>
        </Style>
        <Style x:Key="CK" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,2,14,2"/>
        </Style>
        <Style x:Key="DI" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="70"/>
            <Setter Property="Margin"     Value="0,2,4,2"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="4,0,4,8">

        <!-- ══ DI 数字输入状态 ══ -->
        <TextBlock Text="─── DI 数字输入状态（16路）" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <CheckBox Content="DI01"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI02"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI03"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI04"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI05"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI06"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI07"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI08"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI09"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI10"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI11"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI12"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI13"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI14"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI15"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI16"  Style="{StaticResource DI}"/>
        </WrapPanel>

        <!-- ══ DO 数字输出控制 ══ -->
        <TextBlock Text="─── DO 数字输出控制（16路）" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <CheckBox Content="DO01"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO02"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO03"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO04"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO05"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO06"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO07"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO08"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO09"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO10"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO11"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO12"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO13"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO14"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO15"  Style="{StaticResource DI}"/>
            <CheckBox Content="DO16"  Style="{StaticResource DI}"/>
        </WrapPanel>

        <!-- ══ 运行状态 ══ -->
        <TextBlock Text="─── 运行状态" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="控制模式"     Style="{StaticResource FL}"/>
                <ComboBox Style="{StaticResource FC}" SelectedIndex="0">
                    <ComboBoxItem Content="自动"/>
                    <ComboBoxItem Content="手动"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="通信状态"     Style="{StaticResource FL}"/>
                <ComboBox Style="{StaticResource FC}" SelectedIndex="0">
                    <ComboBoxItem Content="正常"/>
                    <ComboBoxItem Content="异常"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="板卡状态"     Style="{StaticResource FL}"/>
                <ComboBox Style="{StaticResource FC}" SelectedIndex="0">
                    <ComboBoxItem Content="正常"/>
                    <ComboBoxItem Content="故障"/>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 故障/告警注入 ══ -->
        <TextBlock Text="─── 故障/告警注入" Style="{StaticResource Sec}"/>

        <TextBlock Text="故障字1：" Foreground="#EF4444" FontSize="12" Margin="0,4,0,2"/>
        <WrapPanel>
            <CheckBox Content="通信中断"     Style="{StaticResource CK}"/>
            <CheckBox Content="控制板故障"   Style="{StaticResource CK}"/>
            <CheckBox Content="电源故障"     Style="{StaticResource CK}"/>
            <CheckBox Content="看门狗复位"   Style="{StaticResource CK}"/>
        </WrapPanel>

        <TextBlock Text="告警字1：" Foreground="#F97316" FontSize="12" Margin="0,6,0,2"/>
        <WrapPanel>
            <CheckBox Content="DI输入异常告警" Style="{StaticResource CK}"/>
            <CheckBox Content="DO输出异常告警" Style="{StaticResource CK}"/>
            <CheckBox Content="短路告警"       Style="{StaticResource CK}"/>
        </WrapPanel>

        <Button Content="一键清除所有故障/告警"
                Height="28" Padding="12,0" Margin="0,10,0,0"
                HorizontalAlignment="Left"
                Background="#374151" Foreground="#F1F5F9"
                BorderThickness="0" FontSize="12" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</UserControl>
