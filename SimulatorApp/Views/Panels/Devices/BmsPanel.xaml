<UserControl x:Class="SimulatorApp.Views.Panels.Devices.BmsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="110"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FB" TargetType="TextBox">
            <Setter Property="Width"      Value="85"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Background" Value="#242840"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3352"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"    Value="6,2"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="4,0"/>
        </Style>
        <Style x:Key="FU" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="36"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="0,0,10,0"/>
        </Style>
        <Style x:Key="FC" TargetType="ComboBox">
            <Setter Property="Width"      Value="120"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Background" Value="#242840"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3352"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="4,0,12,0"/>
        </Style>
        <DataTemplate x:Key="AlarmTpl">
            <CheckBox Content="{Binding Label}"
                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                      Foreground="#CBD5E1" FontSize="12" Margin="0,2,14,2"/>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel Margin="4,0,4,8">

        <!-- ══ 遥测数值 ══ -->
        <TextBlock Text="─── 遥测数值" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="SOC"         Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Soc, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="%"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="SOH"         Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Soh, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="%"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="总电压"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding TotalVolt, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="V"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="总电流"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Current, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="A"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="最高单体电压" Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding MaxCellVolt, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="V"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="最低单体电压" Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding MinCellVolt, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="V"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="压差"         Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding VoltDiff, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="V"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="最高温度"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding MaxCellTemp, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="℃"          Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="最低温度"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding MinCellTemp, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="℃"          Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="允许充电电流" Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding AllowChargeCurr, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="A"           Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="允许放电电流" Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding AllowDischargeCurr, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="A"           Style="{StaticResource FU}"/>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 运行状态 ══ -->
        <TextBlock Text="─── 运行状态" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="系统状态"     Style="{StaticResource FL}"/>
                <ComboBox SelectedIndex="{Binding SystemState, Mode=TwoWay}" Style="{StaticResource FC}">
                    <ComboBoxItem Content="静置"/>
                    <ComboBoxItem Content="充电"/>
                    <ComboBoxItem Content="放电"/>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 故障/告警注入 ══ -->
        <TextBlock Text="─── 故障/告警注入" Style="{StaticResource Sec}"/>

        <TextBlock Text="故障字1：" Foreground="#EF4444" FontSize="12" Margin="0,4,0,2"/>
        <ItemsControl ItemsSource="{Binding Fault1Items}" ItemTemplate="{StaticResource AlarmTpl}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <TextBlock Text="告警字1：" Foreground="#F97316" FontSize="12" Margin="0,6,0,2"/>
        <ItemsControl ItemsSource="{Binding Alarm1Items}" ItemTemplate="{StaticResource AlarmTpl}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Button Content="一键清除所有故障/告警"
                Command="{Binding ClearAllFaultsCommand}"
                Height="28" Padding="12,0" Margin="0,10,0,0"
                HorizontalAlignment="Left"
                Background="#374151" Foreground="#F1F5F9"
                BorderThickness="0" FontSize="12" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</UserControl>
