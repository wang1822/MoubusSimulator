<UserControl x:Class="SimulatorApp.Views.Panels.Devices.DehumidifierPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="130"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FB" TargetType="TextBox">
            <Setter Property="Width"      Value="85"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Background" Value="#242840"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3352"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"    Value="6,2"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="4,0"/>
        </Style>
        <Style x:Key="FU" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="45"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="0,0,10,0"/>
        </Style>
        <Style x:Key="FC" TargetType="ComboBox">
            <Setter Property="Width"      Value="160"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Background" Value="#242840"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3352"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="4,0,12,0"/>
        </Style>
        <Style x:Key="CK" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,2,14,2"/>
        </Style>
        <!-- 快捷内联行模板 -->
        <DataTemplate x:Key="AlarmTpl">
            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}" Style="{StaticResource CK}"/>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel Margin="4,0,4,8">

        <!-- ══ 版本/设备信息（FX 0x1001-0x1008）══ -->
        <TextBlock Text="─── 版本 / 设备信息" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="硬件版本"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding HwVersion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text=""               Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="软件版本"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding SwVersion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text=""               Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="设备编号"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"  Style="{StaticResource FB}"/>
                <TextBlock Text=""               Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="软件日期(HEX)"  Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding SwDate, UpdateSourceTrigger=PropertyChanged}"    Style="{StaticResource FB}"/>
                <TextBlock Text=""               Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="心跳值"         Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Heartbeat, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text=""               Style="{StaticResource FU}"/>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 遥测数值（FX 0x100D-0x1013）══ -->
        <TextBlock Text="─── 遥测数值" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="温度"           Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}"   Style="{StaticResource FB}"/>
                <TextBlock Text="℃"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="湿度"           Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Humidity, UpdateSourceTrigger=PropertyChanged}"      Style="{StaticResource FB}"/>
                <TextBlock Text="%RH"            Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="NTC1 温度"      Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Ntc1Temp, UpdateSourceTrigger=PropertyChanged}"     Style="{StaticResource FB}"/>
                <TextBlock Text="℃"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="NTC2 温度"      Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Ntc2Temp, UpdateSourceTrigger=PropertyChanged}"     Style="{StaticResource FB}"/>
                <TextBlock Text="℃"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="输入电压"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding InputVoltage, UpdateSourceTrigger=PropertyChanged}"  Style="{StaticResource FB}"/>
                <TextBlock Text="V"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="输出电压"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding OutputVoltage, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="mV"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="TEC 电流"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding TecCurrent, UpdateSourceTrigger=PropertyChanged}"   Style="{StaticResource FB}"/>
                <TextBlock Text="mA"             Style="{StaticResource FU}"/>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 工作时长（FX 0x1014-0x101F）══ -->
        <TextBlock Text="─── 工作时长" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="主板工作时长"   Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding MainBoardRuntime, UpdateSourceTrigger=PropertyChanged}"    Style="{StaticResource FB}"/>
                <TextBlock Text="h"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机1 时长"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan1Runtime, UpdateSourceTrigger=PropertyChanged}"         Style="{StaticResource FB}"/>
                <TextBlock Text="h"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机2 时长"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan2Runtime, UpdateSourceTrigger=PropertyChanged}"         Style="{StaticResource FB}"/>
                <TextBlock Text="h"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机3 时长"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan3Runtime, UpdateSourceTrigger=PropertyChanged}"         Style="{StaticResource FB}"/>
                <TextBlock Text="h"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机4 时长"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan4Runtime, UpdateSourceTrigger=PropertyChanged}"         Style="{StaticResource FB}"/>
                <TextBlock Text="h"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="除湿模块时长"   Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding DehumiModuleRuntime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="h"              Style="{StaticResource FU}"/>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 风机电流（FX 0x1020-0x1023）══ -->
        <TextBlock Text="─── 风机电流" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机1 电流"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan1Current, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="mA"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机2 电流"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan2Current, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="mA"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机3 电流"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan3Current, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="mA"             Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="风机4 电流"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding Fan4Current, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="mA"             Style="{StaticResource FU}"/>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 参数寄存器（FX 0x7031-0x7035）══ -->
        <TextBlock Text="─── 参数设定（FX 0x7031-0x7035）" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="除湿设定点"     Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding DehumiSetPoint, UpdateSourceTrigger=PropertyChanged}"    Style="{StaticResource FB}"/>
                <TextBlock Text="%RH"            Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="除湿回差"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding DehumiReturnDiff, UpdateSourceTrigger=PropertyChanged}"  Style="{StaticResource FB}"/>
                <TextBlock Text="%RH"            Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="过电压值"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding OverVoltageSet, UpdateSourceTrigger=PropertyChanged}"    Style="{StaticResource FB}"/>
                <TextBlock Text="V"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="欠电压值"       Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding UnderVoltageSet, UpdateSourceTrigger=PropertyChanged}"   Style="{StaticResource FB}"/>
                <TextBlock Text="V"              Style="{StaticResource FU}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="电压保护回差"   Style="{StaticResource FL}"/>
                <TextBox   Text="{Binding VoltageHysteresis, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FB}"/>
                <TextBlock Text="V"              Style="{StaticResource FU}"/>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 运行指令（FX 0x6011/0x6012）══ -->
        <TextBlock Text="─── 运行指令" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="运行指令"       Style="{StaticResource FL}"/>
                <ComboBox  SelectedIndex="{Binding RunCmd}" Style="{StaticResource FC}">
                    <ComboBoxItem Content="停止 (关机 0x6012)"/>
                    <ComboBoxItem Content="自动除湿 (0x6011→01)"/>
                    <ComboBoxItem Content="强制除湿 (0x6011→02)"/>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 状态字（FX 0x1009-0x100A，U32 bitmask）══ -->
        <TextBlock Text="─── 状态字（FX: 0x1009-0x100A）" Style="{StaticResource Sec}"/>
        <TextBlock Text="各 bit=1 表示该模式当前有效" Foreground="#64748B" FontSize="11" Margin="0,0,0,4"/>
        <ItemsControl ItemsSource="{Binding StatusItems}" ItemTemplate="{StaticResource AlarmTpl}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- ══ 故障字（FX 0x100B-0x100C，U32 bitmask）══ -->
        <TextBlock Text="─── 故障字（FX: 0x100B-0x100C）" Style="{StaticResource Sec}"/>
        <TextBlock Text="各 bit=1 表示该故障有效" Foreground="#EF4444" FontSize="11" Margin="0,0,0,4"/>
        <ItemsControl ItemsSource="{Binding FaultItems}" ItemTemplate="{StaticResource AlarmTpl}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Button Content="一键清除所有状态/故障"
                Command="{Binding ClearAllFaultsCommand}"
                Height="28" Padding="12,0" Margin="0,10,0,0"
                HorizontalAlignment="Left"
                Background="#374151" Foreground="#F1F5F9"
                BorderThickness="0" FontSize="12" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </StackPanel>
</UserControl>
