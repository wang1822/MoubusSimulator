<UserControl x:Class="SimulatorApp.Views.Panels.Devices.StsControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="110"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FC" TargetType="ComboBox">
            <Setter Property="Width"      Value="120"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Background" Value="#242840"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3352"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="4,0,12,0"/>
        </Style>
        <Style x:Key="CK" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,2,14,2"/>
        </Style>
        <Style x:Key="DI" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="80"/>
            <Setter Property="Margin"     Value="0,2,6,2"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="4,0,4,8">

        <!-- ══ DI 数字输入状态 ══ -->
        <TextBlock Text="─── DI 数字输入状态" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <CheckBox Content="DI1" Style="{StaticResource DI}"/>
            <CheckBox Content="DI2" Style="{StaticResource DI}"/>
            <CheckBox Content="DI3" Style="{StaticResource DI}"/>
            <CheckBox Content="DI4" Style="{StaticResource DI}"/>
            <CheckBox Content="DI5" Style="{StaticResource DI}"/>
            <CheckBox Content="DI6" Style="{StaticResource DI}"/>
            <CheckBox Content="DI7" Style="{StaticResource DI}"/>
            <CheckBox Content="DI8" Style="{StaticResource DI}"/>
            <CheckBox Content="DI9"  Style="{StaticResource DI}"/>
            <CheckBox Content="DI10" Style="{StaticResource DI}"/>
            <CheckBox Content="DI11" Style="{StaticResource DI}"/>
            <CheckBox Content="DI12" Style="{StaticResource DI}"/>
            <CheckBox Content="DI13" Style="{StaticResource DI}"/>
            <CheckBox Content="DI14" Style="{StaticResource DI}"/>
            <CheckBox Content="DI15" Style="{StaticResource DI}"/>
            <CheckBox Content="DI16" Style="{StaticResource DI}"/>
        </WrapPanel>

        <!-- ══ DO 数字输出状态 ══ -->
        <TextBlock Text="─── DO 数字输出状态" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <CheckBox Content="DO1" Style="{StaticResource DI}"/>
            <CheckBox Content="DO2" Style="{StaticResource DI}"/>
            <CheckBox Content="DO3" Style="{StaticResource DI}"/>
            <CheckBox Content="DO4" Style="{StaticResource DI}"/>
            <CheckBox Content="DO5" Style="{StaticResource DI}"/>
            <CheckBox Content="DO6" Style="{StaticResource DI}"/>
            <CheckBox Content="DO7" Style="{StaticResource DI}"/>
            <CheckBox Content="DO8" Style="{StaticResource DI}"/>
        </WrapPanel>

        <!-- ══ 运行状态 ══ -->
        <TextBlock Text="─── 运行状态" Style="{StaticResource Sec}"/>
        <WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="控制模式"     Style="{StaticResource FL}"/>
                <ComboBox Style="{StaticResource FC}" SelectedIndex="0">
                    <ComboBoxItem Content="自动"/>
                    <ComboBoxItem Content="手动"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="通信状态"     Style="{StaticResource FL}"/>
                <ComboBox Style="{StaticResource FC}" SelectedIndex="0">
                    <ComboBoxItem Content="正常"/>
                    <ComboBoxItem Content="异常"/>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <!-- ══ 故障/告警注入 ══ -->
        <TextBlock Text="─── 故障/告警注入" Style="{StaticResource Sec}"/>

        <TextBlock Text="故障字1：" Foreground="#EF4444" FontSize="12" Margin="0,4,0,2"/>
        <WrapPanel>
            <CheckBox Content="通信中断"     Style="{StaticResource CK}"/>
            <CheckBox Content="IO板故障"    Style="{StaticResource CK}"/>
            <CheckBox Content="电源故障"     Style="{StaticResource CK}"/>
        </WrapPanel>

        <TextBlock Text="告警字1：" Foreground="#F97316" FontSize="12" Margin="0,6,0,2"/>
        <WrapPanel>
            <CheckBox Content="DI输入异常"   Style="{StaticResource CK}"/>
            <CheckBox Content="DO输出异常"   Style="{StaticResource CK}"/>
        </WrapPanel>

        <Button Content="一键清除所有故障/告警"
                Height="28" Padding="12,0" Margin="0,10,0,0"
                HorizontalAlignment="Left"
                Background="#374151" Foreground="#F1F5F9"
                BorderThickness="0" FontSize="12" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</UserControl>
