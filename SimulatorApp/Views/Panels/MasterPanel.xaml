                    <TextBlock Foreground="#64748B" FontSize="12" Margin="0,0,0,16"
                               Text="通过 FC16 写保持寄存器，向目标从站下发控制指令（需先连接并建立通信）。"/>

                    <!-- 当前 EMS 状态摘要 -->
                    <Border Background="#161B2E" BorderBrush="#2E3352" BorderThickness="1"
                            CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="当前 EMS 状态" Foreground="#64748B" FontSize="11" Margin="0,0,0,8"/>
                            <WrapPanel Orientation="Horizontal">
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,4">
                                    <TextBlock Text="系统状态：" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SystemStateText}" Foreground="#F1F5F9" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,4">
                                    <TextBlock Text="控制模式：" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ModeStateText}" Foreground="#F1F5F9" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,4">
                                    <TextBlock Text="SOC：" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Soc, StringFormat=F1}" Foreground="#22C55E" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    <TextBlock Text=" %" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="告警/故障：" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Foreground="#F1F5F9" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} / {1}">
                                                <Binding Path="AlarmNum"/><Binding Path="FaultNum"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <WrapPanel Orientation="Horizontal">

                        <!-- ─── SOC 限值 (addr 114-115) ─── -->
                        <Border Style="{StaticResource CtrlCardStyle}">
                            <StackPanel>
                                <TextBlock Text="SOC 充放电限值" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="地址 114（上限）/ 115（下限），单位 %，FC16 写入" Style="{StaticResource SecLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                                    <TextBlock Text="SOC 上限" Foreground="#94A3B8" FontSize="12"
                                               Width="80" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CtrlSocUpper, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputBoxStyle}" Width="80"/>
                                    <TextBlock Text="%" Foreground="#64748B" FontSize="12"
                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="SOC 下限" Foreground="#94A3B8" FontSize="12"
                                               Width="80" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CtrlSocLower, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputBoxStyle}" Width="80"/>
                                    <TextBlock Text="%" Foreground="#64748B" FontSize="12"
                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="写入 SOC 限值" Command="{Binding WriteSocLimitsCommand}"
                                        IsEnabled="{Binding IsConnected}"
                                        Style="{StaticResource WriteBtn}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <!-- ─── 控制模式 (addr 116) ─── -->
                        <Border Style="{StaticResource CtrlCardStyle}">
                            <StackPanel>
                                <TextBlock Text="控制模式切换" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="地址 116，0=本地  1=远程，FC16 写入" Style="{StaticResource SecLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,14">
                                    <Border Width="120" Height="36" CornerRadius="6" Margin="0,0,8,0"
                                            BorderThickness="1" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"   Value="#1E2840"/>
                                                <Setter Property="BorderBrush"  Value="#2E3352"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCtrlModeLocal}" Value="True">
                                                        <Setter Property="Background"  Value="#1D3A5F"/>
                                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <RadioButton Content="本地控制" IsChecked="{Binding IsCtrlModeLocal}"
                                                     Foreground="#F1F5F9" FontSize="13"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                                     Background="Transparent" BorderThickness="0"/>
                                    </Border>
                                    <Border Width="120" Height="36" CornerRadius="6"
                                            BorderThickness="1" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"   Value="#1E2840"/>
                                                <Setter Property="BorderBrush"  Value="#2E3352"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCtrlModeRemote}" Value="True">
                                                        <Setter Property="Background"  Value="#1D3A5F"/>
                                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <RadioButton Content="远程控制" IsChecked="{Binding IsCtrlModeRemote}"
                                                     Foreground="#F1F5F9" FontSize="13"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                                     Background="Transparent" BorderThickness="0"/>
                                    </Border>
                                </StackPanel>
                                <Button Content="写入控制模式" Command="{Binding WriteControlModeCommand}"
                                        IsEnabled="{Binding IsConnected}"
                                        Style="{StaticResource WriteBtn}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <!-- ─── 有功功率设定 (addr 117) ─── -->
                        <Border Style="{StaticResource CtrlCardStyle}">
                            <StackPanel>
                                <TextBlock Text="有功功率设定值" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="地址 117，正值=充电，负值=放电，FC16 写入" Style="{StaticResource SecLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,12">
                                    <TextBlock Text="功率设定" Foreground="#94A3B8" FontSize="12"
                                               Width="80" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CtrlPower, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputBoxStyle}" Width="110"/>
                                    <TextBlock Text="W" Foreground="#64748B" FontSize="12"
                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="写入功率设定值" Command="{Binding WriteActivePowerCommand}"
                                        IsEnabled="{Binding IsConnected}"
                                        Style="{StaticResource WriteBtn}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- ═══════════════════════════════════════════════
             通讯日志
        ════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0A0D14" BorderBrush="#2E3352" BorderThickness="0,1,0,0">
            <Grid Margin="12,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="通讯日志" Foreground="#64748B" FontSize="11" Margin="0,0,0,4"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding CommLog}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#94A3B8" FontFamily="Consolas" FontSize="11"
                         VirtualizingPanel.ScrollUnit="Item"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding"    Value="2,1"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

    </Grid>
</UserControl>
