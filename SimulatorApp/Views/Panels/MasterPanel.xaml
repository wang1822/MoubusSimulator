<UserControl x:Class="SimulatorApp.Views.Panels.MasterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SimulatorApp.Converters">

    <UserControl.Resources>
        <conv:BoolToColorConverter  x:Key="ConnColorConv"   TrueColor="#22C55E" FalseColor="#64748B" />
        <conv:BoolToColorConverter  x:Key="OnlineColorConv" TrueColor="#22C55E" FalseColor="#EF4444" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:BoolToStringConverter     x:Key="BoolStr" />

        <!-- ── 卡片 ── -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"        Value="#1C2033" />
            <Setter Property="BorderBrush"       Value="#2E3352" />
            <Setter Property="BorderThickness"   Value="1" />
            <Setter Property="CornerRadius"      Value="8" />
            <Setter Property="Padding"           Value="12,10" />
            <Setter Property="Margin"            Value="0,0,8,8" />
            <Setter Property="Width"             Value="280" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <!-- 遥控专用宽卡片 -->
        <Style x:Key="CtrlCardStyle" TargetType="Border">
            <Setter Property="Background"        Value="#1C2033" />
            <Setter Property="BorderBrush"       Value="#2E3352" />
            <Setter Property="BorderThickness"   Value="1" />
            <Setter Property="CornerRadius"      Value="8" />
            <Setter Property="Padding"           Value="16,14" />
            <Setter Property="Margin"            Value="0,0,12,12" />
            <Setter Property="Width"             Value="300" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#F1F5F9" />
            <Setter Property="FontSize"    Value="13" />
            <Setter Property="FontWeight"  Value="SemiBold" />
            <Setter Property="Margin"      Value="0,0,0,8" />
        </Style>

        <Style x:Key="SecLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#475569" />
            <Setter Property="FontSize"    Value="10" />
            <Setter Property="Margin"      Value="0,8,0,4" />
        </Style>

        <!-- 字段标签 -->
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#94A3B8" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Width"             Value="110" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 字段值 -->
        <Style x:Key="FV" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#F1F5F9" />
            <Setter Property="FontSize"          Value="13" />
            <Setter Property="FontFamily"        Value="Consolas" />
            <Setter Property="MinWidth"          Value="70" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 单位 -->
        <Style x:Key="FU" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#64748B" />
            <Setter Property="FontSize"          Value="11" />
            <Setter Property="Margin"            Value="3,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 主按钮 -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB" />
            <Setter Property="Foreground"      Value="#F1F5F9" />
            <Setter Property="Height"          Value="30" />
            <Setter Property="Padding"         Value="12,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}"
                                Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                            <Trigger Property="IsMouseOver" Value="True" ><Setter Property="Background" Value="#1D4ED8"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框 -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background"               Value="#242840" />
            <Setter Property="Foreground"               Value="#F1F5F9" />
            <Setter Property="BorderBrush"              Value="#2E3352" />
            <Setter Property="Height"                   Value="28" />
            <Setter Property="Padding"                  Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize"                 Value="12" />
        </Style>

        <!-- Tab 按钮（RadioButton 模拟） -->
        <Style x:Key="TabBtnStyle" TargetType="RadioButton">
            <Setter Property="Height"          Value="40" />
            <Setter Property="Padding"         Value="20,0" />
            <Setter Property="Foreground"      Value="#64748B" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 在线状态指示 TextBlock 样式 -->
        <Style x:Key="OnlineText" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground"        Value="#EF4444" />
        </Style>

        <!-- 写入按钮（绿色） -->
        <Style x:Key="WriteBtn" TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
            <Setter Property="Background" Value="#16A34A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#15803D"/></Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="#0F1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 连接配置栏 -->
            <RowDefinition Height="Auto"/>   <!-- Tab 切换按钮栏 -->
            <RowDefinition Height="*"/>      <!-- 内容区 -->
            <RowDefinition Height="130"/>    <!-- 通讯日志 -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════
             连接配置栏
        ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1C2033" BorderBrush="#2E3352"
                BorderThickness="0,0,0,1" Padding="16,10">
            <WrapPanel Orientation="Horizontal">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="协议：" Foreground="#94A3B8" FontSize="13"
                               VerticalAlignment="Center" Width="45"/>
                    <RadioButton Content="TCP" Foreground="#F1F5F9" FontSize="13"
                                 IsChecked="{Binding IsTcp}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="RTU" Foreground="#F1F5F9" FontSize="13"
                                 IsChecked="{Binding IsRtu}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                            Visibility="{Binding IsTcp, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="主机：" Foreground="#94A3B8" Width="40" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBoxStyle}" Width="130" Margin="0,0,10,0"/>
                    <TextBlock Text="端口：" Foreground="#94A3B8" Width="40" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBoxStyle}" Width="60" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                            Visibility="{Binding IsRtu, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="串口：" Foreground="#94A3B8" Width="40" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Text="{Binding ComPort, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBoxStyle}" Width="80" Margin="0,0,10,0"/>
                    <TextBlock Text="波特率：" Foreground="#94A3B8" Width="52" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Text="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBoxStyle}" Width="70" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="SlaveId：" Foreground="#94A3B8" Width="60" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBoxStyle}" Width="46" Margin="0,0,12,0"/>
                    <TextBlock Text="间隔(ms)：" Foreground="#94A3B8" Width="68" VerticalAlignment="Center" FontSize="13"/>
                    <TextBox Text="{Binding PollIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBoxStyle}" Width="60"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Width="88" Margin="0,0,6,0" Command="{Binding ConnectCommand}"
                            Content="{Binding IsConnected, Converter={StaticResource BoolStr}, ConverterParameter='断开连接|连接'}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="启动轮询" Command="{Binding StartPollingCommand}" Width="78" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                                <Setter Property="Background" Value="#16A34A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False"><Setter Property="IsEnabled" Value="False"/></DataTrigger>
                                    <DataTrigger Binding="{Binding IsPolling}"   Value="True" ><Setter Property="IsEnabled" Value="False"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="停止轮询" Command="{Binding StopPollingCommand}" Width="78" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                                <Setter Property="Background" Value="#D97706"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPolling}" Value="False"><Setter Property="IsEnabled" Value="False"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="读取一次" Command="{Binding ReadOnceCommand}" Width="78" Margin="0,0,16,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                                <Setter Property="Background" Value="#374151"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False"><Setter Property="IsEnabled" Value="False"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0"
                             Fill="{Binding IsConnected, Converter={StaticResource ConnColorConv}}"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="  ● 轮询中" Foreground="#22C55E" FontSize="12" VerticalAlignment="Center"
                               Visibility="{Binding IsPolling, Converter={StaticResource BoolVis}}"/>
                </StackPanel>

            </WrapPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════
             Tab 切换按钮栏
        ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#12162A" BorderBrush="#2E3352" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,0">
                <RadioButton x:Name="TelemTab" GroupName="MasterTabs" IsChecked="True"
                             Content="📡  遥测监控" Style="{StaticResource TabBtnStyle}"/>
                <RadioButton x:Name="CtrlTab"  GroupName="MasterTabs"
                             Content="🎛  遥调遥控" Style="{StaticResource TabBtnStyle}"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════
             内容区
        ════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- ────────────────────────────────────────
                 遥测监控 面板
            ──────────────────────────────────────── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Visibility>
                    <Binding ElementName="TelemTab" Path="IsChecked" Converter="{StaticResource BoolVis}"/>
                </ScrollViewer.Visibility>
                <WrapPanel Margin="12,10,4,4" Orientation="Horizontal">

                    <!-- ─── EMS 总览 ─── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="⚡  EMS 总览" Style="{StaticResource CardTitleStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="系统状态"   Style="{StaticResource FL}"/>
                                <TextBlock Text="{Binding SystemStateText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource FV}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SystemStateText}" Value="运行"><Setter Property="Foreground" Value="#22C55E"/></DataTrigger>
                                                <DataTrigger Binding="{Binding SystemStateText}" Value="故障"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger>
                                                <DataTrigger Binding="{Binding SystemStateText}" Value="告警"><Setter Property="Foreground" Value="#F59E0B"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="运行场景"   Style="{StaticResource FL}"/><TextBlock Text="{Binding RunSceneText}"     Style="{StaticResource FV}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="工况"       Style="{StaticResource FL}"/><TextBlock Text="{Binding DefineSceneText}"  Style="{StaticResource FV}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="控制模式"   Style="{StaticResource FL}"/><TextBlock Text="{Binding ModeStateText}"    Style="{StaticResource FV}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="PCS 在线"   Style="{StaticResource FL}"/><TextBlock Text="{Binding PcsOnlineNum}"     Style="{StaticResource FV}"/><TextBlock Text="台" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="告警 / 故障" Style="{StaticResource FL}"/>
                                <TextBlock Style="{StaticResource FV}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} / {1}">
                                            <Binding Path="AlarmNum"/><Binding Path="FaultNum"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="─  电量  ─────────────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="SOC"        Style="{StaticResource FL}"/><TextBlock Text="{Binding Soc,  StringFormat=F1}" Style="{StaticResource FV}"/><TextBlock Text="%" Style="{StaticResource FU}"/></StackPanel>
                            <ProgressBar Value="{Binding Soc}" Minimum="0" Maximum="100"
                                         Height="5" Margin="0,1,0,3" Foreground="#22C55E"
                                         Background="#374151" BorderThickness="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="SOH"        Style="{StaticResource FL}"/><TextBlock Text="{Binding Soh,  StringFormat=F1}" Style="{StaticResource FV}"/><TextBlock Text="%" Style="{StaticResource FU}"/></StackPanel>
                            <TextBlock Text="─  功率  ─────────────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="PCS 有功"   Style="{StaticResource FL}"/><TextBlock Text="{Binding PcsActivePower,  StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kW" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="电池功率"   Style="{StaticResource FL}"/><TextBlock Text="{Binding BatteryPower,     StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kW" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="电网有功"   Style="{StaticResource FL}"/><TextBlock Text="{Binding GridActivePower, StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kW" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="负荷有功"   Style="{StaticResource FL}"/><TextBlock Text="{Binding LoadActivePower, StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kW" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="PV 输出"    Style="{StaticResource FL}"/><TextBlock Text="{Binding PvOutputPower,   StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kW" Style="{StaticResource FU}"/></StackPanel>
                            <TextBlock Text="─  电能  ─────────────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="今日充电"   Style="{StaticResource FL}"/><TextBlock Text="{Binding TodayCharge,        StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kWh" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="今日放电"   Style="{StaticResource FL}"/><TextBlock Text="{Binding TodayDischarge,     StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kWh" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="累计充电"   Style="{StaticResource FL}"/><TextBlock Text="{Binding CumulativeCharge,    StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kWh" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="累计放电"   Style="{StaticResource FL}"/><TextBlock Text="{Binding CumulativeDischarge, StringFormat=F2}" Style="{StaticResource FV}"/><TextBlock Text="kWh" Style="{StaticResource FU}"/></StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ─── 外部电表 ─── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="📊  外部电表（#1）" Style="{StaticResource CardTitleStyle}" Margin="0"/>
                                <Ellipse Width="8" Height="8" Margin="8,0,4,0" VerticalAlignment="Center"
                                         Fill="{Binding MOnline, Converter={StaticResource OnlineColorConv}}"/>
                                <TextBlock Text="{Binding MOnline, Converter={StaticResource BoolStr}, ConverterParameter='在线|离线'}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource OnlineText}">
                                            <Style.Triggers><DataTrigger Binding="{Binding MOnline}" Value="True"><Setter Property="Foreground" Value="#22C55E"/></DataTrigger></Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="─  功率  ─────────────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="总有功"     Style="{StaticResource FL}"/><TextBlock Text="{Binding MTolActivePower,   StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="kW"   Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="总无功"     Style="{StaticResource FL}"/><TextBlock Text="{Binding MTolReactivePower, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="kvar" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="功率因数"   Style="{StaticResource FL}"/><TextBlock Text="{Binding MPowerFactor,      StringFormat=F3}" Style="{StaticResource FV}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="频率"       Style="{StaticResource FL}"/><TextBlock Text="{Binding MFrequency,        StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="Hz"   Style="{StaticResource FU}"/></StackPanel>
                            <TextBlock Text="─  电压 / 电流  ───────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="L1 电压"    Style="{StaticResource FL}"/><TextBlock Text="{Binding ML1Voltage, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="V" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="L2 电压"    Style="{StaticResource FL}"/><TextBlock Text="{Binding ML2Voltage, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="V" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="L3 电压"    Style="{StaticResource FL}"/><TextBlock Text="{Binding ML3Voltage, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="V" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="L1 电流"    Style="{StaticResource FL}"/><TextBlock Text="{Binding ML1Current, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="A" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="L2 电流"    Style="{StaticResource FL}"/><TextBlock Text="{Binding ML2Current, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="A" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="L3 电流"    Style="{StaticResource FL}"/><TextBlock Text="{Binding ML3Current, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="A" Style="{StaticResource FU}"/></StackPanel>
                            <TextBlock Text="─  电能  ─────────────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="正向电能"   Style="{StaticResource FL}"/><TextBlock Text="{Binding MPosActiveCharge, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="kWh" Style="{StaticResource FU}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="反向电能"   Style="{StaticResource FL}"/><TextBlock Text="{Binding MRevActiveCharge, StringFormat=F3}" Style="{StaticResource FV}"/><TextBlock Text="kWh" Style="{StaticResource FU}"/></StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ─── PCS ─── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="🔌  PCS（#1）" Style="{StaticResource CardTitleStyle}" Margin="0"/>
                                <Ellipse Width="8" Height="8" Margin="8,0,4,0" VerticalAlignment="Center"
                                         Fill="{Binding PcsOnline, Converter={StaticResource OnlineColorConv}}"/>
                                <TextBlock Text="{Binding PcsOnline, Converter={StaticResource BoolStr}, ConverterParameter='在线|离线'}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource OnlineText}">
                                            <Style.Triggers><DataTrigger Binding="{Binding PcsOnline}" Value="True"><Setter Property="Foreground" Value="#22C55E"/></DataTrigger></Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="运行状态"   Style="{StaticResource FL}"/><TextBlock Text="{Binding PcsOperatingStateText}" Style="{StaticResource FV}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="充放电状态" Style="{StaticResource FL}"/><TextBlock Text="{Binding PcsChargingStateText}"  Style="{StaticResource FV}"/></StackPanel>
                            <TextBlock Text="─  直流侧  ───────────────" Style="{StaticResource SecLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2"><TextBlock Text="直流电压"   Style="{StaticResource FL}"/><TextBlock Text="{Binding PcsDcVoltage,  StringFormat=F1}" Style="{StaticResource FV}"/><TextBlock Text="V"  Style="{StaticResource FU}"/></StackPanel>
