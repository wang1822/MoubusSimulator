<UserControl x:Class="SimulatorApp.Views.Controls.FieldRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Orientation="Horizontal" Margin="0,2">
        <!-- 标签 140px -->
        <TextBlock x:Name="LabelText"
                   Width="140" VerticalAlignment="Center"
                   Foreground="#94A3B8" FontSize="12"
                   TextTrimming="CharacterEllipsis" />
        <!-- 输入框 100px -->
        <TextBox   x:Name="ValueBox"
                   Width="100" Height="28" Margin="4,0"
                   Background="#242840" Foreground="#F1F5F9"
                   BorderBrush="#2E3352" BorderThickness="1"
                   Padding="6,4" FontSize="13"
                   VerticalContentAlignment="Center" />
        <!-- 单位 50px -->
        <TextBlock x:Name="UnitText"
                   Width="50" VerticalAlignment="Center"
                   Foreground="#64748B" FontSize="12" />
    </StackPanel>
</UserControl>
