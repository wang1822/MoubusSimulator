<UserControl x:Class="SimulatorApp.Views.Controls.DeviceExpander"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Expander x:Name="Root"
              Background="#1C2033"
              BorderBrush="#2E3352" BorderThickness="1"
              Margin="0,4"
              Padding="8,4">

        <Expander.Header>
            <TextBlock x:Name="TitleText"
                       Foreground="#F1F5F9" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </Expander.Header>

        <ContentPresenter x:Name="Body" Margin="8,4" />
    </Expander>
</UserControl>
