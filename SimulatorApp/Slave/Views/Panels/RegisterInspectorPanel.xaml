<UserControl x:Class="SimulatorApp.Slave.Views.Panels.RegisterInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SimulatorApp.Slave.ViewModels"
             Background="{StaticResource SurfaceBrush}">
    <!--
        寄存器检视器面板
        DataContext = RegisterInspectorViewModel
        功能：手动输入地址，实时读写 RegisterBank，类似 Modbus Slave 数据表
    -->
    <DockPanel>

        <!-- ===== 顶部工具栏 ===== -->
        <Border DockPanel.Dock="Top" Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>

                <!-- 第一行：批量加载 -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="批量加载：起始地址" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="70" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding BatchStart, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="起始寄存器地址（十进制）"/>
                    <TextBlock Text="  数量" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="8,0,6,0"/>
                    <TextBox Width="55" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding BatchCount, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="加载寄存器数量（最多 256）"/>
                    <Button Content="📥 批量加载" Command="{Binding LoadBatchCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0" ToolTip="加载指定范围的寄存器地址到表格"/>
                </WrapPanel>

                <!-- 第二行：添加单行 + 全局操作 -->
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="添加单地址：" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="70" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="寄存器地址（十进制，0~65535）">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddRowCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="＋ 添加" Command="{Binding AddRowCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,0"/>
                    <Button Content="↻ 刷新全部" Command="{Binding RefreshAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="12,0,0,0"
                            ToolTip="从 RegisterBank 重新读取所有行的当前值"/>
                    <Button Content="🗑 清空" Command="{Binding ClearRowsCommand}"
                            Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0"/>
                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- ===== 寄存器数据表格 ===== -->
        <DataGrid ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{StaticResource BackgroundBrush}"
                  RowBackground="Transparent"
                  AlternatingRowBackground="#0D1526"
                  BorderThickness="0"
                  RowHeight="32"
                  FontFamily="Consolas"
                  FontSize="13"
                  SelectionMode="Single">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="Padding"    Value="8,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground"     Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="8,2"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <!-- 地址（只读） -->
                <DataGridTextColumn Header="地址(Dec)" Binding="{Binding Address}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="地址(Hex)" Binding="{Binding AddrHex}" Width="90" IsReadOnly="True"/>

                <!-- 值（可直接编辑，回车后同步写入 RegisterBank） -->
                <DataGridTextColumn Header="值(Dec)"
                                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                    Width="100"/>
                <DataGridTextColumn Header="值(Hex)" Binding="{Binding HexValue}" Width="90" IsReadOnly="True"/>

                <!-- 备注（用户自由填写） -->
                <DataGridTextColumn Header="备注"
                                    Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>

                <!-- 写入 + 删除按钮列 -->
                <DataGridTemplateColumn Header="操作" Width="120" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vm:InspectorRow}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="写入" Width="46" Height="22" Margin="2,0"
                                        FontSize="11" Padding="0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        ToolTip="将当前 Dec 值写入 RegisterBank"
                                        Click="WriteButton_Click"/>
                                <Button Content="删除" Width="46" Height="22" Margin="2,0"
                                        FontSize="11" Padding="0"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="DeleteButton_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>
