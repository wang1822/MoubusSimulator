<UserControl x:Class="SimulatorApp.Slave.Views.Panels.ImportedDevicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="12,6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding DeviceName}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Border>

        <!-- 寄存器表格 -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="{StaticResource BackgroundBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  RowBackground="{StaticResource BackgroundBrush}"
                  AlternatingRowBackground="{StaticResource SurfaceBrush}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  CanUserResizeRows="False"
                  SelectionMode="Single">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"   Value="#1C2033"/>
                    <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="Padding"      Value="10,5"/>
                    <Setter Property="FontSize"     Value="11"/>
                    <Setter Property="FontWeight"   Value="SemiBold"/>
                    <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="10,4"/>
                    <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="FontFamily"      Value="Consolas, Courier New"/>
                    <Setter Property="FontSize"        Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2563EB22"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="中文名"   Binding="{Binding ChineseName}" Width="*"  MinWidth="100"/>
                <DataGridTextColumn Header="地址 Dec" Binding="{Binding Address}"     Width="90"/>
                <DataGridTextColumn Header="地址 Hex" Binding="{Binding AddressHex}"  Width="90"/>
                <DataGridTextColumn Header="值 Dec"   Binding="{Binding ValueDec}"    Width="90"/>
                <DataGridTextColumn Header="值 Hex"   Binding="{Binding ValueHex}"    Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
