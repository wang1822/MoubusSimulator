<UserControl x:Class="SimulatorApp.Slave.Views.Panels.SlavePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="clr-namespace:SimulatorApp.Slave.Views.Panels"
             xmlns:conv="clr-namespace:SimulatorApp.Shared.Converters"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToColorConverter x:Key="BoolToColor"/>
        <conv:BoolToStringConverter x:Key="BoolToString"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Border Padding="6,5" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <!-- 设备勾选框：勾选后启动监听生效、自动模拟运行、导出时包含此设备 -->
                    <CheckBox DockPanel.Dock="Right"
                              IsChecked="{Binding IsSimulating, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="4,0,0,0"
                              ToolTip="勾选后：启动监听时寄存器生效，定时模拟运行，导出时包含此设备"
                              Click="OnSimCheckBoxClick"/>
                    <TextBlock Text="{Binding DeviceName}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部连接配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 中间内容区（左侧设备列表 + 右侧设备面板） -->
            <RowDefinition Height="*"/>
            <!-- 底部日志区 -->
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部：监听配置列表 ===== -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="10,6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>

                <!-- 标题栏：全局操作按钮 -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left" Text="监听配置"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="↻" Width="26" Height="26" Margin="0,0,6,0"
                                Command="{Binding RefreshTcpAddressesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="14"
                                ToolTip="刷新本地网卡 IP 和串口列表"/>
                        <Button Content="＋ 新增监听" Height="26" Padding="8,0" Margin="0,0,6,0"
                                Command="{Binding AddListenerCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="添加一条新的监听端点配置"/>
                        <Button Content="▶ 启动全部" Height="26" Padding="8,0" Margin="0,0,6,0"
                                Command="{Binding StartAllListenersCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="启动所有已勾选且未运行的监听"/>
                        <Button Content="⏹ 停止全部" Height="26" Padding="8,0"
                                Command="{Binding StopAllListenersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="停止所有正在运行的监听"/>
                    </WrapPanel>
                </DockPanel>

                <!-- 监听配置列表 -->
                <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Listeners}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" Padding="6,3"
                                        Background="#0D1117"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="3">
                                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                                        <!-- 是否启用 -->
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                                  ToolTip="勾选后才会被「启动全部」包含"/>

                                        <!-- 协议 -->
                                        <ComboBox Width="60" Height="24"
                                                  ItemsSource="{Binding ProtocolNames}"
                                                  SelectedIndex="{Binding ProtocolIndex, Mode=TwoWay}"
                                                  Style="{StaticResource DataComboBoxStyle}"
                                                  Margin="0,0,6,0"/>

                                        <!-- TCP 配置 -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                                            <ComboBox Width="130" Height="24" IsEditable="True"
                                                      ItemsSource="{Binding DataContext.AvailableTcpAddresses,
                                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource DataComboBoxStyle}"
                                                      Margin="0,0,4,0"/>
                                            <TextBlock Text=":" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,2,0"/>
                                            <TextBox Width="52" Height="24"
                                                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DataTextBoxStyle}"
                                                     Margin="0,0,6,0"/>
                                        </StackPanel>

                                        <!-- RTU 配置 -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                                            <ComboBox Width="80" Height="24"
                                                      ItemsSource="{Binding DataContext.AvailableComPorts,
                                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding ComPort, Mode=TwoWay}"
                                                      Style="{StaticResource DataComboBoxStyle}"
                                                      Margin="0,0,4,0"/>
                                            <ComboBox Width="80" Height="24"
                                                      ItemsSource="{Binding DataContext.BaudRateOptions,
                                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding BaudRate, Mode=TwoWay}"
                                                      Style="{StaticResource DataComboBoxStyle}"
                                                      Margin="0,0,6,0"/>
                                        </StackPanel>

                                        <!-- Slave ID -->
                                        <TextBlock Text="ID:" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" Margin="0,0,3,0"/>
                                        <TextBox Width="36" Height="24"
                                                 Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DataTextBoxStyle}"
                                                 Margin="0,0,10,0"/>

                                        <!-- 状态指示灯 + 文字 -->
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,4,0"
                                                 Fill="{Binding IsRunning, Converter={StaticResource BoolToColor},
                                                        ConverterParameter='#22C55E|#475569'}"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{Binding IsRunning, Converter={StaticResource BoolToColor},
                                                               ConverterParameter='#22C55E|#94A3B8'}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   MinWidth="90" Margin="0,0,10,0"/>

                                        <!-- 启动/停止 -->
                                        <Button Height="24" Padding="8,0" Margin="0,0,4,0"
                                                Content="{Binding IsRunning, Converter={StaticResource BoolToString},
                                                          ConverterParameter='⏹ 停止|▶ 启动'}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding DataContext.ToggleListenerCommand,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>

                                        <!-- 删除 -->
                                        <Button Height="24" Width="24" Content="×" Padding="0"
                                                FontSize="13"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.RemoveListenerCommand,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="删除此监听配置"/>
                                    </WrapPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 全局状态行 + 工具按钮 -->
                <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColor},
                                    ConverterParameter='#22C55E|#475569'}"/>
                    <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToString},
                                      ConverterParameter='监听中|已停止'}"
                               Foreground="{Binding IsRunning, Converter={StaticResource BoolToColor},
                                           ConverterParameter='#22C55E|#94A3B8'}"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding RequestCount, StringFormat='请求总计：{0}'}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" FontSize="11" Margin="0,0,20,0"/>

                    <Button Content="📊 导出设备Excel" Command="{Binding ExportDeviceExcelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                            ToolTip="将所有已勾选设备导出为多 Sheet Excel"/>
                    <Button Content="📂 导入设备Excel" Command="{Binding ImportDeviceExcelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="📋 粘贴导入" Command="{Binding PasteImportDeviceCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"
                            ToolTip="在 Excel 中复制数据行后点此，自动识别设备类型并追加到列表底部"/>
                    <Button Content="📸 导出快照" Command="{Binding ExportSnapshotCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="📂 导入快照" Command="{Binding ImportSnapshotCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- ===== 中间内容区 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左侧设备选择列表 -->
                <ColumnDefinition Width="160" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <!-- 右侧设备面板 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧设备列表 -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- 设备选择列表 -->
                    <ListBox ItemsSource="{Binding DeviceList}"
                             SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                             ItemTemplate="{StaticResource DeviceItemTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2563EB22"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 分隔条（可拖拽） -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

            <!-- 右侧设备面板（根据 SelectedDevice 类型切换） -->
            <ContentControl Grid.Column="2" Content="{Binding SelectedDevicePanel}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>

        <!-- ===== 底部日志区 ===== -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <!-- 日志标题栏 -->
                <Border DockPanel.Dock="Top" Padding="12,4"
                        Background="#13192D"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="运行日志" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="清空" Width="50" Height="22"
                                Command="{Binding ClearLogCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="4,0"/>
                    </DockPanel>
                </Border>

                <!-- 日志内容 -->
                <ScrollViewer x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}"
                                           FontFamily="Consolas, Courier New"
                                           FontSize="11"
                                           Padding="12,1"
                                           Foreground="{Binding Level, Converter={StaticResource BoolToColor}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                    <Setter Property="Foreground" Value="#F97316"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
