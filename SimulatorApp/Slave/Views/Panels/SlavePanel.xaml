<UserControl x:Class="SimulatorApp.Slave.Views.Panels.SlavePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="clr-namespace:SimulatorApp.Slave.Views.Panels"
             xmlns:conv="clr-namespace:SimulatorApp.Shared.Converters"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToColorConverter x:Key="BoolToColor"/>
        <conv:BoolToStringConverter x:Key="BoolToString"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Border Padding="8,6" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding DeviceName}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部连接配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 中间内容区（左侧设备列表 + 右侧设备面板） -->
            <RowDefinition Height="*"/>
            <!-- 底部日志区 -->
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部连接配置区 ===== -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- 第一行：连接配置 + 启停 + 状态 -->
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 协议选择（用 SelectedIndex 绑定，避免 int→ProtocolType 类型转换错误） -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                        <TextBlock Text="协议：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="80" Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding ProtocolNames}"
                                  SelectedIndex="{Binding ProtocolIndex, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- TCP 配置（协议=TCP时显示） -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                                Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="监听地址：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <!-- IsEditable=True 允许手动输入自定义 IP -->
                        <ComboBox Width="140" Style="{StaticResource DataComboBoxStyle}"
                                  IsEditable="True"
                                  ItemsSource="{Binding AvailableTcpAddresses}"
                                  Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="↻" Width="26" Height="26" Margin="4,0,0,0"
                                Command="{Binding RefreshTcpAddressesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="14"
                                ToolTip="重新检测本地网卡 IP"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                                Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="端口：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Width="70" Style="{StaticResource DataTextBoxStyle}"
                                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- RTU 配置（协议=RTU时显示） -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                                Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="串口：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="90" Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding AvailableComPorts}"
                                  SelectedItem="{Binding ComPort, Mode=TwoWay}"/>
                        <Button Content="↻" Width="26" Height="26" Margin="4,0,0,0"
                                Command="{Binding RefreshComPortsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                                Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="波特率：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="90" Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding BaudRateOptions}"
                                  SelectedItem="{Binding BaudRate, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Slave ID（公共） -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                        <TextBlock Text="Slave ID：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Width="50" Style="{StaticResource DataTextBoxStyle}"
                                 Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- 启动/停止按钮 -->
                    <Button Content="{Binding IsRunning, Converter={StaticResource BoolToString}, ConverterParameter='⏹ 停止监听|▶ 启动监听'}"
                            Command="{Binding ToggleSlaveCommand}"
                            Width="110" Height="32"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,12,4"/>

                    <!-- 运行状态指示灯 -->
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColor}, ConverterParameter='#22C55E|#475569'}"/>
                    <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToString}, ConverterParameter='监听中|已停止'}"
                               Foreground="{Binding IsRunning, Converter={StaticResource BoolToColor}, ConverterParameter='#22C55E|#94A3B8'}"
                               VerticalAlignment="Center" FontSize="12"/>
                </WrapPanel>

                <!-- 第二行：工具按钮（始终在独立行，不会被挤掉） -->
                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="📊 导出设备Excel" Command="{Binding ExportDeviceExcelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="📂 导入设备Excel" Command="{Binding ImportDeviceExcelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="📸 导出快照(JSON)" Command="{Binding ExportSnapshotCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="📂 导入快照(JSON)" Command="{Binding ImportSnapshotCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ===== 中间内容区 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左侧设备选择列表 -->
                <ColumnDefinition Width="160" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <!-- 右侧设备面板 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧设备列表 -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- 底部"+"导入按钮 -->
                    <Button DockPanel.Dock="Bottom"
                            Content="＋ 导入自定义设备"
                            Command="{Binding ImportCustomDeviceCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="6,4" Height="32" FontSize="12"/>

                    <!-- 设备选择列表 -->
                    <ListBox ItemsSource="{Binding DeviceList}"
                             SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                             ItemTemplate="{StaticResource DeviceItemTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2563EB22"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 分隔条（可拖拽） -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

            <!-- 右侧设备面板（根据 SelectedDevice 类型切换） -->
            <ContentControl Grid.Column="2" Content="{Binding SelectedDevicePanel}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>

        <!-- ===== 底部日志区 ===== -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <!-- 日志标题栏 -->
                <Border DockPanel.Dock="Top" Padding="12,4"
                        Background="#13192D"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="运行日志" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="清空" Width="50" Height="22"
                                Command="{Binding ClearLogCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="4,0"/>
                    </DockPanel>
                </Border>

                <!-- 日志内容 -->
                <ScrollViewer x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}"
                                           FontFamily="Consolas, Courier New"
                                           FontSize="11"
                                           Padding="12,1"
                                           Foreground="{Binding Level, Converter={StaticResource BoolToColor}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                    <Setter Property="Foreground" Value="#F97316"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
